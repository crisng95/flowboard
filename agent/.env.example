# Flowboard Agent — environment template
# Copy to `.env.staging` (gitignored) for local/staging, or set these in your
# hosting provider's secret manager for production. NEVER commit real values.
#
# In production set FLOWBOARD_ENV=prod: the agent will REFUSE to boot if any
# required secret below is missing or still a placeholder.

# ── Deployment mode ──────────────────────────────────────────────────────────
# "dev" (default) keeps developer-friendly fallbacks; "prod" enables hard guards.
FLOWBOARD_ENV=dev

# ── Supabase Control Plane (required in prod) ────────────────────────────────
# Project URL, e.g. https://YOUR_PROJECT_REF.supabase.co
SUPABASE_URL=
# Service-role key (full DB access — bypasses RLS). Keep secret.
SUPABASE_SERVICE_ROLE_KEY=

# ── Cron / stale-job recovery (required in prod) ─────────────────────────────
# Long random string. The default placeholder is rejected when FLOWBOARD_ENV=prod.
CONTROL_PLANE_CRON_TOKEN=

# ── Cloudflare R2 object storage (required in prod) ──────────────────────────
R2_ENDPOINT=
R2_BUCKET=flowboard-assets
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ── Google Flow public web API key (optional override) ───────────────────────
# Not a private credential (Flow's web app ships it to every browser), but
# kept configurable so it can be rotated without a code change.
FLOW_API_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins. In prod set the real
# frontend origin(s), e.g. https://app.flowboard.bond
FLOWBOARD_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Extension worker (cloud-worker mode) ─────────────────────────────────────
CONTROL_PLANE_BASE_URL=http://127.0.0.1:8101
EXT_CLIENT_ID=
EXT_PAIRING_SECRET=
EXT_PROVIDER=mock
EXT_POLL_INTERVAL_SEC=5
EXT_HEARTBEAT_INTERVAL_SEC=20
EXT_LEASE_DURATION_SEC=60

# ── Local runtime (optional) ─────────────────────────────────────────────────
# FLOWBOARD_HTTP_PORT=8101
# FLOWBOARD_WS_HOST=127.0.0.1
# FLOWBOARD_EXT_WS_PORT=9223
# FLOWBOARD_PLANNER_MODEL=claude-sonnet-4-6
# FLOWBOARD_PLANNER_BACKEND=auto
