{
  "manifest_version": 3,
  "name": "Flowboard Bridge",
  "version": "0.0.6",
  "description": "Flowboard extension worker for authenticated Google Flow sessions.",
  "permissions": ["storage", "alarms", "tabs", "webRequest", "scripting", "declarativeNetRequest"],
  "host_permissions": [
    "https://aisandbox-pa.googleapis.com/*",
    "https://labs.google/*",
    "https://flow-content.google/*",
    "https://lh3.googleusercontent.com/*",
    "https://*.r2.cloudflarestorage.com/*",
    "http://127.0.0.1:8101/*",
    "http://localhost:8101/*"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Flowboard Bridge",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://labs.google/fx/tools/flow*",
        "https://labs.google/fx/*/tools/flow*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://labs.google/*"]
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "flowboard_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
